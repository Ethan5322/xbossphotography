# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── CallMeBot (WhatsApp Notifications) ───────────────────────────────────────
# Your WhatsApp phone number WITH country code, no + (e.g. 27821234567)
CALLMEBOT_PHONE=27821234567
# Your CallMeBot API key (from the setup message you sent to CallMeBot)
CALLMEBOT_APIKEY=your-callmebot-key-here

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Password to log into the admin panel — choose something strong
ADMIN_PASSWORD=your-secure-password-here
# Secret key for signing admin session tokens — generate a random 32+ char string
ADMIN_JWT_SECRET=your-random-secret-key-minimum-32-characters-here

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for QR code links in the PDF. Change to your Vercel domain when deployed.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
